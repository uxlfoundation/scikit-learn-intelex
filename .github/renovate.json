{
  "dependencyDashboard": false,
  "extends": [
    "config:recommended",
    ":preserveSemverRanges"
  ],
  "pip_requirements": {
    "managerFilePatterns": [
      "/(^|/)requirements.*\\.txt$/",
      "/(^|/)dependencies-dev$/"
    ]
  },
  "packageRules": [
    {
      "groupName": "Doc packages",
      "matchUpdateTypes": ["patch", "minor"],
      "schedule": ["before 2am on the first day of the month"],
      "matchFileNames": ["requirements-doc.txt"]
    }
  ],
  "pre-commit": {
    "enabled": true
  },
"customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.ci/pipeline/build-and-test-lnx\\.yml$/",
        "/^\\.github/workflows/ci\\.yml$/"
      ],
      "matchStrings": [
        "\\s*DPCTL_VERSION: (?<currentValue>\\d+\\.\\d+\\.\\d+)"
      ],
      "depNameTemplate": "dpctl",
      "datasourceTemplate": "pypi"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.ci/pipeline/build-and-test-lnx\\.yml$/",
        "/^\\.github/workflows/ci\\.yml$/"
      ],
      "matchStrings": [
        "\\s*DPNP_VERSION: (?<currentValue>\\d+\\.\\d+\\.\\d+)"
      ],
      "depNameTemplate": "dpnp",
      "datasourceTemplate": "pypi"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.ci/pipeline/build-and-test-lnx\\.yml$/"],
      "matchStrings": [
        "\\s*DPCPP_VERSION: (?<currentValue>\\d+\\.\\d+\\.\\d+)"
      ],
      "depNameTemplate": "dpcpp_linux-64",
      "datasourceTemplate": "conda",
      "registryUrlTemplate": "https://conda.anaconda.org/conda-forge"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.ci/pipeline/linting\\.yml$/"],
      "matchStrings": ["pre-commit==(?<currentValue>\\d+\\.\\d+\\.\\d+)"],
      "depNameTemplate": "pre-commit",
      "datasourceTemplate": "pypi"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["(^|/)meta\\.ya?ml$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\s*\\n\\s*-\\s*[\"']\\S+\\s+<=(?<currentValue>[^\"']+)[\"']"
      ],
    }
  ]
}

